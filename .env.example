# AlgoCoach Configuration
# Config is auto-created at ~/.algocoach/.env when you run 'algocoach start'.
# Edit that file to set your API keys. This file is for reference only.

# AI provider: google, groq, or nvidia
AI_PROVIDER=google

# API keys (get from https://aistudio.google.com, https://console.groq.com, https://build.nvidia.com)
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Optional overrides
AI_MODEL=
PORT=3000
