# AlgoCoach Environment Variables

# Server
PORT=3000
CORS_ORIGIN=http://localhost:5173

# Neon PostgreSQL (get from https://neon.tech)
DATABASE_URL=postgres://user:pass@ep-example.us-east-2.aws.neon.tech/neondb?sslmode=require

# Better Auth
BETTER_AUTH_SECRET=your-secret-key-here-min-32-chars-long
BETTER_AUTH_URL=http://localhost:3000

# Resend (for verification emails, get from https://resend.com)
RESEND_API_KEY=
RESEND_FROM_EMAIL=noreply@algo-coach.com

# OAuth Providers (optional for development)
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
