# AlgoCoach Configuration
# Copy or symlink this to ~/.algocoach/.env and fill in your keys.

# AI provider: google, groq, or nvidia
AI_PROVIDER=google

# API keys (get from https://aistudio.google.com, https://console.groq.com, https://build.nvidia.com)
GEMINI_API_KEY=
GROQ_API_KEY=
NVIDIA_API_KEY=

# Optional overrides
AI_MODEL=
PORT=3000
