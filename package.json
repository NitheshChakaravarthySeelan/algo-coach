{
  "name": "algocoach",
  "version": "0.1.3",
  "type": "module",
  "bin": {
    "algocoach": "cli/index.ts"
  },
  "files": [
    "cli/",
    "dist/",
    "server/"
  ],
  "scripts": {
    "dev": "concurrently \"bun run dev:client\" \"bun run dev:server\"",
    "dev:client": "vite",
    "dev:server": "bun run --hot cli/index.ts serve",
    "build": "tsc -b && vite build",
    "prepack": "vite build",
    "lint": "eslint .",
    "test": "bun test",
    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@better-auth/drizzle-adapter": "^1.6.15",
    "@google/genai": "^2.8.0",
    "autoprefixer": "^10.5.0",
    "better-auth": "^1.6.15",
    "drizzle-orm": "^0.45.2",
    "framer-motion": "^12.40.0",
    "groq-sdk": "^1.2.1",
    "hono": "^4.12.25",
    "lucide-react": "^1.17.0",
    "openai": "^6.43.0",
    "postcss": "^8.5.15",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-router-dom": "^7.17.0",
    "recharts": "^3.8.1",
    "tailwindcss": "3",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.1",
    "bun-types": "^1.3.14",
    "concurrently": "^10.0.3",
    "drizzle-kit": "^0.31.10",
    "eslint": "^10.3.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.2",
    "globals": "^17.6.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.59.2",
    "vite": "^8.0.12"
  }
}
